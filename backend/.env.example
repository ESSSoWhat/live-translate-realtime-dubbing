# ─────────────────────────────────────────────────────────────────────────────
# Live Translate Backend — environment variables
#
# Copy this file to ".env" in the same directory and fill in the values.
# DO NOT commit ".env" to version control.
#
# Minimum required to run locally (auth + Google OAuth):
#   SUPABASE_URL, SUPABASE_SERVICE_ROLE_KEY, SUPABASE_JWT_SECRET
#
# Minimum required for voice proxy endpoints:
#   ELEVENLABS_API_KEY
#
# Stripe keys are now optional — billing endpoints return 503 when absent.
# ─────────────────────────────────────────────────────────────────────────────

# ── Supabase (REQUIRED for auth / OAuth) ─────────────────────────────────────
# Get these from: https://supabase.com/dashboard → your project → Settings → API
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_JWT_SECRET=your-jwt-secret-from-supabase-api-settings

# ── ElevenLabs (REQUIRED for voice synthesis) ────────────────────────────────
ELEVENLABS_API_KEY=your-elevenlabs-api-key

# ── OpenAI (optional — used for translation fallback) ────────────────────────
OPENAI_API_KEY=

# ── Stripe (optional — billing endpoints disabled when absent) ───────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_STARTER_PRICE_ID=
STRIPE_PRO_PRICE_ID=

# ── App ───────────────────────────────────────────────────────────────────────
BACKEND_ENV=development
BACKEND_CORS_ORIGINS=*
