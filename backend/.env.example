# ─────────────────────────────────────────────────────────────────────────────
# Live Translate Backend — environment variables
#
# Copy this file to ".env" in the same directory and fill in the values.
# DO NOT commit ".env" to version control.
#
# Minimum required to run locally (auth + Google OAuth):
#   SUPABASE_URL, SUPABASE_SERVICE_ROLE_KEY, SUPABASE_JWT_SECRET
#
# Minimum required for voice proxy endpoints (with usage tracking):
#   ELEVENLABS_API_KEY, SUPABASE_DB_URL
#
# Stripe keys are now optional — billing endpoints return 503 when absent.
# ─────────────────────────────────────────────────────────────────────────────

# ── Supabase (REQUIRED for auth / OAuth) ─────────────────────────────────────
# Get these from: https://supabase.com/dashboard → your project → Settings → API
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_JWT_SECRET=your-jwt-secret-from-supabase-api-settings

# ── Supabase Direct DB (REQUIRED for usage quota tracking) ───────────────────
# Get from: Supabase Dashboard → Settings → Database → Connection string (URI)
# Connection pooling (use in app / server): port 6543, ?pgbouncer=true
# Direct connection (use for migrations only): port 5432
# Example for project in ap-southeast-1:
#   DATABASE_URL (pooler): postgresql://postgres.[project-ref]:[YOUR-PASSWORD]@aws-1-[region].pooler.supabase.com:6543/postgres?pgbouncer=true
#   DIRECT_URL (migrations): postgresql://postgres.[project-ref]:[YOUR-PASSWORD]@aws-1-[region].pooler.supabase.com:5432/postgres
SUPABASE_DB_URL=postgresql://postgres.[project-ref]:your-password@aws-0-[region].pooler.supabase.com:6543/postgres
# Optional: direct URL for migrations (Prisma/Drizzle/etc). If unset, migrations may use SUPABASE_DB_URL.
# DIRECT_URL=postgresql://postgres.[project-ref]:your-password@aws-0-[region].pooler.supabase.com:5432/postgres
# ── ElevenLabs (REQUIRED for voice synthesis) ────────────────────────────────
ELEVENLABS_API_KEY=your-elevenlabs-api-key

# ── OpenAI (optional — used for translation fallback) ────────────────────────
OPENAI_API_KEY=

# ── Stripe (optional — billing endpoints disabled when absent) ───────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_STARTER_PRICE_ID=
STRIPE_PRO_PRICE_ID=

# ── Qonversion (optional — webhook to sync subscription tier from app/web) ─
# From Qonversion Dashboard → Integrations → Webhooks: use the auth token as secret
QONVERSION_WEBHOOK_SECRET=

# ── Wix (optional — sync tier from Wix Pricing Plans; call from Velo with secret)
# Generate a long random string; send as header X-Wix-Sync-Secret or Authorization: Bearer <secret>
WIX_SYNC_SECRET=

# ── App ───────────────────────────────────────────────────────────────────────
BACKEND_ENV=development
# BACKEND_CORS_ORIGINS: Do NOT use "*" in production — it is insecure.
# Use a comma-separated list of explicit origins, e.g.:
#   BACKEND_CORS_ORIGINS=https://app.example.com,https://admin.example.com
# For local dev only you may use BACKEND_CORS_ORIGINS=*
BACKEND_CORS_ORIGINS=https://localhost:3000,http://localhost:3000
