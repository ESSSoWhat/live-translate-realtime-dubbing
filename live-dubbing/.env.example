# Copy to .env and set your keys. Do not commit .env.

# Backend API key (from livetranslate.net account page or Wix SSO)
# LIVE_TRANSLATE_API_KEY=your-api-key-here

# Optional: direct ElevenLabs (bypasses backend)
# ELEVENLABS_API_KEY=your-elevenlabs-key

# Optional: OpenAI for translation
# OPENAI_API_KEY=your-key-here
